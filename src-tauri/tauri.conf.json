{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkNote",
  "version": "0.2.0",
  "identifier": "com.april.marknote",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MarkNote",
        "width": 600,
        "height": 400,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "fullscreen": false,
        "resizable": true,
        "center": true,
        "backgroundColor": "#00000000",
        "visibleOnAllWorkspaces": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
